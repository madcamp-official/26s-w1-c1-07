# Client build-time env (Vite). Copy to client/.env (git-ignored) before building/deploying:
#   cp client/.env.example client/.env
#
# VITE_* vars are inlined into the client bundle AT BUILD TIME. If VITE_GOOGLE_CLIENT_ID is
# missing when you run `npm --prefix client run build` (deploy.sh step 1), the "Sign in with
# Google" button ships broken ("VITE_GOOGLE_CLIENT_ID not set"). This is a PUBLIC OAuth client
# id (it's served to every browser in the bundle), not a secret.
VITE_GOOGLE_CLIENT_ID=214115340159-c9n9269uihd9nlkd31269tai176kl05p.apps.googleusercontent.com
