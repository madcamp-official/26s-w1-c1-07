# 배포 대상 설정. 실제 값은 deploy.env 에 넣는다 (deploy.env 는 git 제외).
#   cp deploy.env.example deploy.env   후 각자 값 채우기.
#
# 비밀번호/키는 여기 없다 — DB 비밀번호는 VM 의 server/.env, SSH 키는 각자 ~/.ssh 에.

# SSH 접속 대상. ~/.ssh/config 의 별칭(예: kaistvm)이거나 user@host 형식.
# (KAIST VM 은 내부망 전용. 각자 공개키가 VM authorized_keys 에 등록돼 있어야 함)
DEPLOY_HOST=kaistvm

# 배포 경로 (VM 안). 서버가 여기서 client/dist 정적 서빙 + API + 소켓.
DEPLOY_PATH=/root/madpump

# 서버 포트 / 클라 접속 오리진(= 웹사이트 주소)
PORT=80
CLIENT_ORIGIN=http://172.10.8.242

# HTTPS(도메인/cloudflared) 뒤에 둘 때만 1. HTTP 직결이면 비워둔다.
COOKIE_SECURE=
