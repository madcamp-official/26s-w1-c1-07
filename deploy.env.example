# Deploy target settings. Put the real values in deploy.env (deploy.env is git-ignored).
#   cp deploy.env.example deploy.env   then fill in your own values.
#
# No passwords/keys here — the DB password lives in the VM's server/.env, and SSH keys in your own ~/.ssh.

# SSH target. Either an alias from ~/.ssh/config (e.g. kaistvm) or a user@host string.
# (The KAIST VM is internal-network only. Your public key must be registered in the VM's authorized_keys)
DEPLOY_HOST=kaistvm

# Deploy path (inside the VM). The server statically serves client/dist here + API + socket.
DEPLOY_PATH=/root/madpump

# Server port / client origin (= website address)
PORT=80
CLIENT_ORIGIN=http://172.10.8.242

# Set to 1 only when behind HTTPS (domain/cloudflared). Leave empty for direct HTTP.
COOKIE_SECURE=
