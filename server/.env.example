# ── Prisma / MySQL connection ─────────────────────────────────────────────
# Put the real values in server/.env (do not commit .env).
#
# [When running directly on the deploy VM]  MySQL is at VM localhost:3306:
#   DATABASE_URL="mysql://madpump:<VM_DB_PASSWORD>@localhost:3306/madpump"
#
# [When migrating from my PC to the VM DB]  After connecting local 3306 → VM 3306 via an SSH tunnel:
#   ssh -N -L 3306:localhost:3306 kaistvm     # (keep it running in a separate terminal)
#   DATABASE_URL="mysql://madpump:<VM_DB_PASSWORD>@127.0.0.1:3306/madpump"
#
# [When developing against a local docker(docker-compose) DB]  port 3307:
#   DATABASE_URL="mysql://madpump:devpass@127.0.0.1:3307/madpump"
DATABASE_URL="mysql://madpump:CHANGME@127.0.0.1:3306/madpump"
