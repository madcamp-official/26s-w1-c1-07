// MADPUMP DB 스키마
// 정본(source of truth): docs/ERD.md (v1, 2026-07-03)
// 이 파일은 ERD.md의 "MySQL DDL" 블록을 Prisma로 충실히 옮긴 것이다.
// 스키마 변경 시 → docs/ERD.md 를 먼저 갱신하고, 그 다음 이 파일에 반영한다.
//
// 원본 DDL 대비 의도적 차이(문서화됨, docs/DATABASE.md "구현 노트" 참조):
//  - created_at / played_at / edited_at 에 @default(now()) 추가 (DDL엔 DEFAULT 없음, 편의용 fallback)
//  - score_config.updated_at 은 @updatedAt (자동 갱신)
//  - result / before_result / after_result 는 VARCHAR 대신 enum MatchResult (ERD.md note #16 "값 제한" 이행)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"] // native=개발기(mac), debian-openssl-3.0.x=배포 VM(Ubuntu 22.04)
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 매치/라운드 결과 도메인 — 값은 매치의 고정 참가자 슬롯(playerA/playerB) 기준.
/// (게임 역할 P1/P2는 라이브 계층 전용, DB엔 저장 안 함 — BUILD_PLAN D5)
enum MatchResult {
  A_WIN
  B_WIN
  DRAW
}

/// 분반/그룹
model UserGroup {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique(map: "uq_group_name") @db.VarChar(100)
  isPublic  Boolean  @default(true) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")

  users AppUser[]

  @@map("user_group")
}

/// 로스터 로그인 유저 — 분반별 고정 멤버 명단(prisma/seed.ts)에서 선택해 로그인.
/// (구글 OAuth는 내부망에서 접근 불가라 폐기 — docs/AUTH.md 참조.
///  같은 이름이 다른 분반에 있을 수 있어 nickname 유니크는 분반 단위.)
model AppUser {
  id               BigInt    @id @default(autoincrement())
  nickname         String    @db.VarChar(50)
  uploadedImageKey String?   @map("uploaded_image_key") @db.VarChar(300)
  groupId          BigInt?   @map("group_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  group      UserGroup?  @relation(fields: [groupId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "fk_user_group")
  matchesAsA GameMatch[] @relation("MatchPlayerA")
  matchesAsB GameMatch[] @relation("MatchPlayerB")

  @@unique([groupId, nickname], map: "uq_user_group_nick")
  @@index([groupId], map: "ix_user_group")
  @@map("app_user")
}

/// 관리자 계정 (유저와 별도 인증)
model AdminAccount {
  id        BigInt   @id @default(autoincrement())
  loginId   String   @unique(map: "uq_admin_login") @map("login_id") @db.VarChar(50)
  pwHash    String   @map("pw_hash") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  editHistories MatchEditHistory[]
  scoreConfigs  ScoreConfig[]

  @@map("admin_account")
}

/// 게임 종류 사전 (코드 미러, 시드로 관리) — ERD.md note #15. 시드 10행(game1~10)
model Game {
  id       Int     @id @db.TinyInt // 코드와 고정 매핑(1~10). AUTO_INCREMENT 아님 — 시드로 주입
  name     String  @unique(map: "uq_game_name") @db.VarChar(50)
  isActive Boolean @default(true) @map("is_active")

  rounds GameRound[]

  @@map("game")
}

/// 매치 결과 (온라인 매치만 기록) — ERD.md note #2.
/// 매치 = 여러 라운드(BUILD_PLAN D3). game_id는 라운드로 이동(라운드마다 게임 랜덤).
/// result = 매치 최종 승자(playerA/playerB 슬롯 기준, 라운드 다승 집계 결과).
model GameMatch {
  id        BigInt      @id @default(autoincrement())
  playerAId BigInt      @map("player_a_id")
  playerBId BigInt      @map("player_b_id")
  result    MatchResult
  playedAt  DateTime    @default(now()) @map("played_at")
  deletedAt DateTime?   @map("deleted_at") // soft delete — ERD.md note #3

  playerA AppUser @relation("MatchPlayerA", fields: [playerAId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "fk_match_pa")
  playerB AppUser @relation("MatchPlayerB", fields: [playerBId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "fk_match_pb")

  rounds        GameRound[]
  editHistories MatchEditHistory[]

  @@index([playerAId, playedAt], map: "ix_match_pa")
  @@index([playerBId, playedAt], map: "ix_match_pb")
  @@index([playedAt], map: "ix_match_played")
  @@map("game_match")
}

/// 라운드 결과 (매치당 여러 행) — BUILD_PLAN D5.
/// 라운드마다 게임 랜덤(gameType) + 역할 랜덤. result = 그 라운드 승자(playerA/B 슬롯 기준).
model GameRound {
  id         BigInt      @id @default(autoincrement())
  matchId    BigInt      @map("match_id")
  roundIndex Int         @map("round_index")
  gameType   Int         @map("game_type") @db.TinyInt
  result     MatchResult

  match GameMatch @relation(fields: [matchId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "fk_round_match")
  game  Game      @relation(fields: [gameType], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "fk_round_game")

  @@unique([matchId, roundIndex], map: "uq_round_match_idx")
  @@index([gameType], map: "ix_round_game")
  @@map("game_round")
}

/// 매치 결과 수정이력 (감사 로그) — ERD.md note #5
model MatchEditHistory {
  id           BigInt      @id @default(autoincrement())
  matchId      BigInt      @map("match_id")
  adminId      BigInt      @map("admin_id")
  beforeResult MatchResult @map("before_result")
  afterResult  MatchResult @map("after_result")
  editedAt     DateTime    @default(now()) @map("edited_at")

  match GameMatch    @relation(fields: [matchId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "fk_meh_match")
  admin AdminAccount @relation(fields: [adminId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "fk_meh_admin")

  @@index([matchId, editedAt], map: "ix_meh_match")
  @@map("match_edit_history")
}

/// 점수 시스템 설정 (admin 수정 가능, 단일 행 id=1) — ERD.md note #17
model ScoreConfig {
  id         Int      @id @db.TinyInt // 항상 1 (단일 행)
  winPoints  Int      @default(3) @map("win_points")
  drawPoints Int      @default(1) @map("draw_points")
  lossPoints Int      @default(0) @map("loss_points")
  updatedAt  DateTime @updatedAt @map("updated_at")
  updatedBy  BigInt?  @map("updated_by")

  updatedByAdmin AdminAccount? @relation(fields: [updatedBy], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "fk_cfg_admin")

  @@map("score_config")
}
