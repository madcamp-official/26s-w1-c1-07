// MADCADE DB schema
// source of truth (canonical): docs/ERD.md (v1, 2026-07-03)
// This file faithfully ports the "MySQL DDL" block of ERD.md into Prisma.
// When changing the schema → update docs/ERD.md first, then reflect it here.
//
// Intentional differences from the original DDL (documented, see docs/DATABASE.md "Implementation notes"):
//  - added @default(now()) on created_at / played_at / edited_at (the DDL has no DEFAULT, a convenience fallback)
//  - score_config.updated_at uses @updatedAt (auto-updated)
//  - result / before_result / after_result use enum MatchResult instead of VARCHAR (implements ERD.md note #16 "value restriction")

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"] // native=dev machine (mac), debian-openssl-3.0.x=deployment VM (Ubuntu 22.04)
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Match/round result domain — values are relative to the match's fixed participant slots (playerA/playerB).
/// (Game roles P1/P2 are live-layer only, not stored in the DB — BUILD_PLAN D5)
enum MatchResult {
  A_WIN
  B_WIN
  DRAW
}

/// Class/group

/// Roster login user — logs in by picking from each class's fixed member list (prisma/seed.ts).
/// (Google OAuth was dropped because it is unreachable on the internal network — see docs/AUTH.md.
///  The same name can appear in different classes, so nickname uniqueness is per class.)
model AppUser {
  id               BigInt    @id @default(autoincrement())
  /// Google account subject (sub claim) — the stable identity key. Login = Google OAuth (docs/AUTH.md v3)
  googleSub        String    @unique(map: "uq_user_google") @map("google_sub") @db.VarChar(64)
  /// Display name (from the Google profile name). Not unique — identity is googleSub.
  nickname         String    @db.VarChar(50)
  email            String?   @db.VarChar(320)
  googleImageUrl   String?   @map("google_image_url") @db.VarChar(500)
  uploadedImageKey String?   @map("uploaded_image_key") @db.VarChar(300)
  /// Coins held (starts at 30) — used for online betting and unlocking offline games (shared/src/coins.ts)
  coins            Int       @default(30)
  /// Number of offline games unlocked (0~7) — the first n are unlocked in UNLOCK_ORDER order
  unlockedCount    Int       @default(0) @map("unlocked_count") @db.TinyInt
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  matchesAsA GameMatch[] @relation("MatchPlayerA")
  matchesAsB GameMatch[] @relation("MatchPlayerB")

  @@map("app_user")
}

/// Admin account (authenticated separately from users)
model AdminAccount {
  id        BigInt   @id @default(autoincrement())
  loginId   String   @unique(map: "uq_admin_login") @map("login_id") @db.VarChar(50)
  pwHash    String   @map("pw_hash") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  editHistories MatchEditHistory[]
  scoreConfigs  ScoreConfig[]

  @@map("admin_account")
}

/// Game type dictionary (code mirror, managed via seed) — ERD.md note #15. 10 seed rows (game1~10)
model Game {
  id       Int     @id @db.TinyInt // fixed mapping to code (1~10). Not AUTO_INCREMENT — injected via seed
  name     String  @unique(map: "uq_game_name") @db.VarChar(50)
  isActive Boolean @default(true) @map("is_active")

  rounds GameRound[]

  @@map("game")
}

/// Match result (only online matches are recorded) — ERD.md note #2.
/// A match = multiple rounds (BUILD_PLAN D3). game_id moved to the round (game is random per round).
/// result = the match's final winner (relative to the playerA/playerB slots, from tallying round wins).
model GameMatch {
  id        BigInt      @id @default(autoincrement())
  playerAId BigInt      @map("player_a_id")
  playerBId BigInt      @map("player_b_id")
  result    MatchResult
  playedAt  DateTime    @default(now()) @map("played_at")
  deletedAt DateTime?   @map("deleted_at") // soft delete — ERD.md note #3

  playerA AppUser @relation("MatchPlayerA", fields: [playerAId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "fk_match_pa")
  playerB AppUser @relation("MatchPlayerB", fields: [playerBId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "fk_match_pb")

  rounds        GameRound[]
  editHistories MatchEditHistory[]

  @@index([playerAId, playedAt], map: "ix_match_pa")
  @@index([playerBId, playedAt], map: "ix_match_pb")
  @@index([playedAt], map: "ix_match_played")
  @@map("game_match")
}

/// Round result (multiple rows per match) — BUILD_PLAN D5.
/// Each round has a random game (gameType) + random roles. result = that round's winner (relative to the playerA/B slots).
model GameRound {
  id         BigInt      @id @default(autoincrement())
  matchId    BigInt      @map("match_id")
  roundIndex Int         @map("round_index")
  gameType   Int         @map("game_type") @db.TinyInt
  result     MatchResult

  match GameMatch @relation(fields: [matchId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "fk_round_match")
  game  Game      @relation(fields: [gameType], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "fk_round_game")

  @@unique([matchId, roundIndex], map: "uq_round_match_idx")
  @@index([gameType], map: "ix_round_game")
  @@map("game_round")
}

/// Match result edit history (audit log) — ERD.md note #5
model MatchEditHistory {
  id           BigInt      @id @default(autoincrement())
  matchId      BigInt      @map("match_id")
  adminId      BigInt      @map("admin_id")
  beforeResult MatchResult @map("before_result")
  afterResult  MatchResult @map("after_result")
  editedAt     DateTime    @default(now()) @map("edited_at")

  match GameMatch    @relation(fields: [matchId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "fk_meh_match")
  admin AdminAccount @relation(fields: [adminId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "fk_meh_admin")

  @@index([matchId, editedAt], map: "ix_meh_match")
  @@map("match_edit_history")
}

/// Scoring system settings (admin-editable, single row id=1) — ERD.md note #17
model ScoreConfig {
  id         Int      @id @db.TinyInt // always 1 (single row)
  winPoints  Int      @default(3) @map("win_points")
  drawPoints Int      @default(1) @map("draw_points")
  lossPoints Int      @default(0) @map("loss_points")
  updatedAt  DateTime @updatedAt @map("updated_at")
  updatedBy  BigInt?  @map("updated_by")

  updatedByAdmin AdminAccount? @relation(fields: [updatedBy], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "fk_cfg_admin")

  @@map("score_config")
}
